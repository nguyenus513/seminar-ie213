{
  "name": "mongodb-indexing-benchmark-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed.js",
    "clear": "node src/scripts/clear.js",
    "index:create": "node src/scripts/createIndexes.js",
    "index:drop": "node src/scripts/dropIndexes.js",
